# ─── Configuración del entorno de tests ──────────────────────────────────────
# Copia este archivo como .env.test y ajusta los valores.
# .env.test NUNCA se sube al repositorio.

# URL base del servidor a testear
# Local:       http://127.0.0.1:5000
# Producción:  https://cueca-chile-production.up.railway.app
BASE_URL=http://127.0.0.1:5000

# Credenciales del administrador
ADMIN_EMAIL=admin@admin.cl
ADMIN_PASSWORD=tu_password_admin

# Credenciales de usuario regular (para tests de roles)
# Si no existe, algunos tests se saltarán
USER_EMAIL=usuario@test.cl
USER_PASSWORD=tu_password_usuario

# Modo headless (true = sin ventana, false = con ventana visible)
HEADLESS=true

# Navegador: chromium | firefox | webkit
BROWSER=chromium
