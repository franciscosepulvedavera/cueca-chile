# ─── Seguridad ───────────────────────────────────────────────
# Genera una clave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-segura

# ─── Base de datos ────────────────────────────────────────────
# PostgreSQL (producción)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/cueca_db

# SQLite (desarrollo local, descomenta esta línea y comenta la de arriba)
# DATABASE_URL=sqlite:///cueca.db

# ─── Imagen (Instagram Story 9:16) ───────────────────────────
IMAGE_STD_WIDTH=1080
IMAGE_STD_HEIGHT=1920

# ─── Administrador inicial (usado por seeds.py) ───────────────
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@tudominio.cl
ADMIN_PASSWORD=CambiaEstePassword123!

# ─── Cloudinary (almacenamiento de imágenes persistente) ──────
# Obtén tu URL en: https://cloudinary.com → Dashboard → API Keys
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Si no está configurado, las imágenes se guardan localmente (se pierden en cada deploy)
# CLOUDINARY_URL=cloudinary://123456789:abcdef@mi-cloud-name
